{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/api/health", "function": { "functionId": "health" } },
      { "source": "/api/enhance-prompt", "function": { "functionId": "enhanceprompt" } },
      { "source": "/api/summarize-role", "function": { "functionId": "summarizerole" } },
      { "source": "/api/design-agent", "function": { "functionId": "designagent" } },
      { "source": "/api/design-workflow", "function": { "functionId": "designworkflow" } },
      { "source": "/api/analyze-architecture", "function": { "functionId": "analyzearchitecture" } },
      { "source": "/api/analyze-insight", "function": { "functionId": "analyzeinsight" } },
      { "source": "/api/generate-pathway", "function": { "functionId": "generatepathway" } },
      { "source": "/api/design-dashboard", "function": { "functionId": "designdashboard" } },
      { "source": "/api/generate-prd", "function": { "functionId": "generateprd" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|svg|ico|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
